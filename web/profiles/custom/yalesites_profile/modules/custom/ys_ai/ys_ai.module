<?php

/**
 * @file
 * Module hooks for the ys_ai module.
 */

use Drupal\Core\Entity\EntityFormInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\ys_ai\Config\BeaconSearchConfigOverride;

/**
 * Implements hook_form_BASE_FORM_ID_alter() for search_api_server_form.
 *
 * The Beacon (Azure AI Search) endpoint URL and index name are supplied at
 * runtime by BeaconSearchConfigOverride when left blank, so they must not be
 * required on the server form — otherwise editors cannot save unrelated
 * changes while the fields appear empty. The field descriptions are replaced
 * to show editors the actual value that will be used when the field is blank
 * and to note that entering a value overrides that default. See
 * \Drupal\ys_ai\Config\BeaconSearchConfigOverride for the value resolution.
 *
 * The fields' #default_value is reset to the override-free stored value so a
 * cleared field displays (and re-saves) as blank. The server config entity is
 * loaded with the override applied, so without this the index name field would
 * show the override-supplied default, which the editor would then unknowingly
 * save and freeze into config, permanently defeating the override.
 */
function ys_ai_form_search_api_server_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  if (!isset($form['backend_config']['database_settings'])) {
    return;
  }

  // Only the Beacon server's URL and index name are managed by the override.
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof EntityFormInterface) {
    return;
  }
  if ('search_api.server.' . $form_object->getEntity()->id() !== BeaconSearchConfigOverride::SERVER_CONFIG_NAME) {
    return;
  }

  // Reset a blank index name back to empty on submit (before the backend's own
  // submit handler stores it), so the validation-time default substitution is
  // not persisted and the override stays authoritative.
  if (isset($form['actions']['submit']['#submit'])) {
    array_unshift($form['actions']['submit']['#submit'], 'ys_ai_beacon_search_server_submit');
  }

  $settings = &$form['backend_config']['database_settings'];

  /** @var \Drupal\ys_ai\Config\BeaconSearchConfigOverride $override */
  $override = \Drupal::service('ys_ai.beacon_search_config_override');

  // Read the stored (override-free) values so the form reflects what is
  // actually saved rather than the override-supplied defaults.
  $stored = \Drupal::service('config.storage')->read(BeaconSearchConfigOverride::SERVER_CONFIG_NAME) ?: [];
  $stored_settings = $stored['backend_config']['database_settings'] ?? [];

  if (isset($settings['url'])) {
    $settings['url']['#required'] = FALSE;
    $settings['url']['#default_value'] = $stored_settings['url'] ?? '';
    $default_url = $override->getAzureUrl();
    $settings['url']['#description'] = $default_url !== ''
      ? t('The default Azure AI Search endpoint, taken from the %key key, is @url. Leave this field blank to use that default; entering a value here overrides it (clear the field to restore the default).', [
        '%key' => 'azure_ai_search_url',
        '@url' => $default_url,
      ])
      : t('The default Azure AI Search endpoint is taken from the %key key. Leave this field blank to use that default; entering a value here overrides it (clear the field to restore the default).', [
        '%key' => 'azure_ai_search_url',
      ]);
  }

  if (isset($settings['database_name'])) {
    $settings['database_name']['#required'] = FALSE;
    $settings['database_name']['#default_value'] = $stored_settings['database_name'] ?? '';
    $default_index = $override->getDatabaseName();
    // The Azure backend rejects an empty index name on save. When the field is
    // left blank, submit the derived default so validation passes;
    // ys_ai_beacon_search_server_submit() then resets it to empty before the
    // value is stored, keeping the override authoritative.
    if ($default_index !== '') {
      $settings['database_name']['#ys_ai_default'] = $default_index;
      $settings['database_name']['#element_validate'][] = 'ys_ai_beacon_search_default_value_validate';
    }
    $settings['database_name']['#description'] = $default_index !== ''
      ? t('The default index for this environment is @index. Leave this field blank to use that default; entering a value here overrides it (clear the field to restore the default).', [
        '@index' => $default_index,
      ])
      : t('The default index for this environment is named @pattern. Leave this field blank to use that default; entering a value here overrides it (clear the field to restore the default).', [
        '@pattern' => '<pantheon-site-name>-<pantheon-environment-name>',
      ]);
  }
}

/**
 * Form element validate callback: substitutes the default when left blank.
 *
 * The Azure AI Search backend rejects an empty index name during validation,
 * which would block saving the Beacon server with the field left blank. When
 * the field is empty we substitute the override-derived default (stored on the
 * element as #ys_ai_default) so validation passes. The submit handler then
 * resets the value to empty before it is stored, so the override remains the
 * single source of truth and the per-environment value is never frozen in.
 */
function ys_ai_beacon_search_default_value_validate(array &$element, FormStateInterface $form_state) {
  $value = $form_state->getValue($element['#parents']);
  if (($value === NULL || $value === '') && !empty($element['#ys_ai_default'])) {
    $form_state->setValueForElement($element, $element['#ys_ai_default']);
  }
}

/**
 * Form submit handler: clears the Beacon index name when left blank.
 *
 * Runs before the search_api backend's own submit handler. The index name is
 * substituted with the override-derived default during validation (see
 * ys_ai_beacon_search_default_value_validate()) to satisfy the Azure backend's
 * "index name required" check. When the editor actually left the field blank,
 * this handler resets the submitted value to empty so the per-environment
 * default is never written to stored config and the override stays
 * authoritative. An explicitly entered value is left untouched.
 */
function ys_ai_beacon_search_server_submit(array &$form, FormStateInterface $form_state) {
  $parents = ['backend_config', 'database_settings', 'database_name'];
  $input = $form_state->getUserInput();
  $entered = $input['backend_config']['database_settings']['database_name'] ?? '';
  if (trim((string) $entered) === '') {
    $form_state->setValue($parents, '');
  }
}

/**
 * Determines whether the Beacon search index is enabled.
 *
 * The native AI metadata fields are only meaningful when content is being
 * indexed for AI, which is governed by the Beacon index's enabled status.
 *
 * @return bool
 *   TRUE when the beacon_index search index exists and is enabled.
 */
function _ys_ai_beacon_index_enabled(): bool {
  $index = \Drupal::entityTypeManager()
    ->getStorage('search_api_index')
    ->load('beacon_index');
  return $index !== NULL && $index->status();
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node_form.
 *
 * The native AI metadata fields (field_ai_exclude / field_ai_description /
 * field_ai_tags) are only relevant when the Beacon search index is enabled.
 * Hide their widgets when it is disabled so editors are not shown controls for
 * a feature that is not active. Field values are stored independently of widget
 * visibility, so hiding never destroys data and the values reappear if the
 * index is re-enabled.
 */
function ys_ai_form_node_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  if (_ys_ai_beacon_index_enabled()) {
    return;
  }
  foreach (['field_ai_exclude', 'field_ai_description', 'field_ai_tags'] as $field_name) {
    if (isset($form[$field_name])) {
      $form[$field_name]['#access'] = FALSE;
    }
  }
}

/**
 * Implements hook_field_widget_single_element_WIDGET_TYPE_form_alter().
 *
 * The legacy AI metatags (the "ai_engine" metatag group provided by
 * ai_engine_metadata) are replaced by the native field_ai_* fields. Remove the
 * group from the metatag widget so editors do not see two competing surfaces
 * for the same data while ai_engine is being phased out.
 */
function ys_ai_field_widget_single_element_metatag_firehose_form_alter(array &$field_widget_complete_form, FormStateInterface $form_state, array $context) {
  if (isset($field_widget_complete_form['ai_engine'])) {
    unset($field_widget_complete_form['ai_engine']);
  }
}
