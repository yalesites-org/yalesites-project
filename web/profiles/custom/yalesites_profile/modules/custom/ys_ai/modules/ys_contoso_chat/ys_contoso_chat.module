<?php

/**
 * @file
 * Yale Chat module hooks.
 */

/**
 * Implements hook_theme().
 */
function ys_contoso_chat_theme() {
  return [
    'ys_contoso_chat_button' => [
      'variables' => [
        'button_text' => NULL,
        'icon_class' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_page_attachments_alter().
 */
function ys_contoso_chat_page_attachments_alter(array &$attachments) {
  $config = \Drupal::config('ys_contoso_chat.settings');
  if (!$config->get('enable')) {
    return;
  }

  $attachments['#cache']['tags'][] = 'config:ys_contoso_chat.settings';
  $attachments['#attached']['drupalSettings']['ys_contoso_chat'] = [
    'initial_questions' => json_encode($config->get('initial_questions')),
    'disclaimer' => (string) check_markup($config->get('disclaimer') ?? '', 'restricted_html'),
    'footer' => (string) check_markup($config->get('footer') ?? '', 'restricted_html'),
  ];
  $attachments['#attached']['library'][] = 'ys_contoso_chat/chat_widget';
}

/**
 * Implements hook_page_bottom().
 */
function ys_contoso_chat_page_bottom(array &$page_bottom) {
  $config = \Drupal::config('ys_contoso_chat.settings');
  $current_theme = \Drupal::theme()->getActiveTheme()->getName();
  $frontend_theme = \Drupal::config('system.theme')->get('default');

  if (
    $config->get('floating_button')
    && $config->get('enable')
    && $current_theme === $frontend_theme
  ) {
    $page_bottom[] = [
      '#theme' => 'ys_contoso_chat_button',
      '#button_text' => $config->get('floating_button_text'),
      '#icon_class' => $config->get('floating_button_icon') ?? 'fa-comments',
    ];
  }
}

/**
 * Implements hook_preprocess_page().
 */
function ys_contoso_chat_preprocess_page(&$variables) {
  $config = \Drupal::config('ys_contoso_chat.settings');
  \Drupal::service('renderer')->addCacheableDependency($variables, $config);
}
