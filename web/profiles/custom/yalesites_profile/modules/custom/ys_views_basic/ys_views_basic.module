<?php

/**
 * @file
 * Contains ys_views_basic.module functions.
 */

use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\node\NodeInterface;
use Drupal\views\ViewExecutable;
use Drupal\ys_views_basic\ViewsBasicManager;

/**
 * Implements hook_theme_suggestions_HOOK_alter() for block.
 *
 * The per-(content type, display mode) listing bundles created by the views
 * rework render identically to the legacy "view" block, but atomic registers
 * block templates by bundle machine name, so the new bundles have no template
 * and fall back to the default block render — printing the padding-options
 * field and losing the heading/CTA styling. Reuse atomic's
 * block--inline-block--view.html.twig for every listing bundle so they are a
 * drop-in replacement (no atomic change required).
 */
function ys_views_basic_theme_suggestions_block_alter(array &$suggestions, array $variables) {
  if (($variables['elements']['#base_plugin_id'] ?? NULL) !== 'inline_block') {
    return;
  }
  $bundle = $variables['elements']['#derivative_plugin_id'] ?? NULL;
  if ($bundle !== NULL && isset(ViewsBasicManager::LISTING_BUNDLES[$bundle])) {
    // Appended last so it takes priority over the (template-less) per-bundle
    // suggestion and resolves to block--inline-block--view.html.twig.
    $suggestions[] = 'block__inline_block__view';
  }
}

/**
 * Implements hook_theme().
 */
function ys_views_basic_theme($existing, $type, $theme, $path): array {
  return [
    // The default formatter will only be used for preview on the back-end.
    'views_basic_formatter_default' => [
      'variables' => [
        'view' => [],
        'exposed' => [],
      ],
    ],
    'views_basic_formatter_preview' => [
      'variables' => [
        'params' => [],
      ],
    ],
    'views_basic_rows' => [
      'variables' => [
        'card_collection_type' => NULL,
        'card_collection_modifiers' => [],
        'rows' => [],
        'parentNode' => NULL,
        'contentType' => NULL,
      ],
    ],
    'views_basic_events_calendar' => [
      'variables' => [
        'month_data' => [],
      ],
    ],
    // Authoring-form live mockup preview panel (#1318); see
    // ViewsBasicWidgetBase::buildPreviewPanel().
    'views_basic_mockup_preview' => [
      'variables' => [
        'content_type' => NULL,
        'view_mode' => NULL,
        'image_src' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_views_data().
 */
function ys_views_basic_views_data_alter(array &$data) {
  $data['node_field_data']['views_basic_sort'] = [
    'title' => t('Views Basic Sort'),
    'sort' => [
      'help' => t('Creates a dynamic sort from Views Basic fields.'),
      'id' => 'views_basic_sort',
    ],
  ];
  $data['node_field_data']['exclude_taxonomy_terms'] = [
    'title' => t('Exclude Taxonomy Terms'),
    'filter' => [
      'help' => t('Excludes taxonomy terms dynamically from the views tool'),
      'id' => 'exclude_taxonomy_terms',
    ],
  ];
  $data['node_field_data']['event_time_period'] = [
    'title' => t('Event Time Period'),
    'filter' => [
      'help' => t('Show future, past, or all events'),
      'id' => 'event_time_period',
    ],
  ];
  $data['node_field_data']['post_year_filter'] = [
    'title' => t('Year'),
    'filter' => [
      'help' => t('Filter posts by year based on publish date.'),
      'id' => 'post_year_filter',
    ],
  ];

}

/**
 * Implements hook_views_pre_build().
 */
function ys_views_basic_views_pre_build($view) {
  static $counter = 0;

  if (empty($view->dom_id)) {
    $view->dom_id = "view_" . $counter++;
  }
}

/**
 * Implements hook_views_pre_render().
 */
function ys_views_basic_views_pre_render(ViewExecutable $view): void {
  $view_id = $view->id();
  if (in_array($view_id, ['views_basic_scaffold', 'views_basic_scaffold_events'])) {
    $pin_options = json_decode($view->args[11]);
    $pin_label = '';
    if ($pin_options->pinned_to_top) {
      $pin_label = $pin_options->pin_label;
    }
    $field_display_options = json_decode($view->args[8]);
    $event_field_display_options = json_decode($view->args[9]);
    $post_field_display_options = json_decode($view->args[10]);
    // Loop through each row in the view's results and update the node's
    // properties based on show_categories, show_tags and show_thumbnail
    // configuration.
    foreach ($view->result as $row) {
      $row->_entity->show_categories = $field_display_options->show_categories;
      $row->_entity->show_tags = $field_display_options->show_tags;
      $row->_entity->show_thumbnail = $field_display_options->show_thumbnail;
      $row->_entity->hide_add_to_calendar = $event_field_display_options->hide_add_to_calendar;
      $row->_entity->show_eyebrow = $post_field_display_options->show_eyebrow;
      // Context-derived heading level for each result card: H3 when the block
      // renders its own heading (the cards nest under it), H2 when the cards
      // are the first heading on the page. The listing node templates read
      // node.card_heading_level (falling back to their own default for non
      // listing renders, which never set this property).
      $row->_entity->card_heading_level = !empty($field_display_options->block_has_heading) ? '3' : '2';

      $sticky = (bool) $row->_entity->get('sticky')->value;
      if ($sticky) {
        $row->_entity->pin_label = $pin_label;
      }
    }
  }
}

/**
 * Implements hook_views_pre_view().
 */
function ys_views_basic_views_pre_view(ViewExecutable $view, $display_id, array &$args) {
  if (!in_array($view->id(), ['views_basic_scaffold', 'views_basic_scaffold_events'])) {
    return;
  }

  // Detect if this is an AJAX request.
  $is_ajax = \Drupal::request()->isXmlHttpRequest();
  if (!$is_ajax) {
    return;
  }

  // setupView() calls ViewExecutable::preview(), which re-fires
  // hook_views_pre_view() for this same view object. Without a guard the hook
  // re-enters setupView() and recurses until PHP exhausts the stack — the
  // Layout Builder "Add Section" AJAX save hangs as a result. Key the guard on
  // the view instance (preview() re-fires the hook with the same object) so a
  // re-entrant call bails while other listing blocks in the same request — each
  // a distinct view object — still run.
  static $processing = [];
  $object_id = spl_object_id($view);
  if (!empty($processing[$object_id])) {
    return;
  }
  $processing[$object_id] = TRUE;
  try {
    $viewsBasicManager = \Drupal::service('ys_views_basic.views_basic_manager');
    // setupView() rebuilds the field-display options from the stored params,
    // which do not carry the host block's heading-presence signal (it is a
    // block-entity fact resolved by the formatter, not a saved param). Recover
    // it from the incoming view arguments so exposed-filter and pager AJAX
    // re-renders keep the same result-card heading level as the initial render.
    // args[8] is the field_display_options JSON (see setupView() arg order).
    $block_has_heading = FALSE;
    if (isset($args[8])) {
      $incoming_display = json_decode($args[8]);
      $block_has_heading = !empty($incoming_display->block_has_heading);
    }
    $viewsBasicManager->setupView($view, end($args), NULL, $block_has_heading);
  }
  finally {
    unset($processing[$object_id]);
  }
}

/**
 * Implements hook_node_view().
 */
function ys_views_basic_node_view(array &$build, NodeInterface $node, EntityViewDisplayInterface $display, $view_mode) {
  $view_modes = [
    "card",
    "portrait_grid",
    "condensed",
    "list_item",
  ];

  if (in_array($view_mode, $view_modes)) {
    $build['#cache']['max-age'] = 0;
  }
}
