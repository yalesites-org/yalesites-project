From 4761c55b5277fba7a296ef9640a704b445574cd0 Mon Sep 17 00:00:00 2001
From: Paul Weidner <paul.weidner@gmail.com>
Date: Wed, 15 Feb 2023 07:11:37 -0800
Subject: [PATCH 2/4] Only depend on description_toggle variable to render
 description toggle

The logic in GinDescriptionToggle::process will only set
description_toggle = TRUE if a description is provided. This function
also has special logic to enable the description toggle for the text
format edge case when the description has been moved from the form
element to the text format wrapper.
---
 templates/form/form-element.html.twig | 11 +++++------
 1 file changed, 5 insertions(+), 6 deletions(-)

diff --git a/templates/form/form-element.html.twig b/templates/form/form-element.html.twig
index dfe2ac7a..856dae04 100644
--- a/templates/form/form-element.html.twig
+++ b/templates/form/form-element.html.twig
@@ -10,7 +10,6 @@
 Most of core-provided js assumes that the CSS class pattern js-form-item-[something] or
 js-form-type-[something] exists on form items. We have to keep them.
 #}
-{% set show_description_toggle = description_toggle and description.content %}
 {%
   set classes = [
     'js-form-item',
@@ -23,7 +22,7 @@ js-form-type-[something] exists on form items. We have to keep them.
     title_display not in ['after', 'before'] ? 'form-item--no-label',
     disabled == 'disabled' ? 'form-item--disabled',
     errors ? 'form-item--error',
-    show_description_toggle ? 'help-icon__description-container'
+    description_toggle ? 'help-icon__description-container'
   ]
 %}
 {%
@@ -34,7 +33,7 @@ js-form-type-[something] exists on form items. We have to keep them.
 %}
 <div{{ attributes.addClass(classes) }}>
   {% if label_display in ['before', 'invisible'] %}
-    {% if show_description_toggle %}
+    {% if description_toggle %}
       <div class="help-icon">
         {{ label }}
         {{ attach_library('gin/gin_description_toggle') }}
@@ -44,7 +43,7 @@ js-form-type-[something] exists on form items. We have to keep them.
       {{ label }}
     {% endif %}
   {% endif %}
-  {% if show_description_toggle %}
+  {% if description_toggle %}
   <div class="help-icon__element-has-description">
   {% endif %}
   {% if prefix is not empty %}
@@ -60,7 +59,7 @@ js-form-type-[something] exists on form items. We have to keep them.
     <span class="form-item__suffix{{disabled == 'disabled' ? ' is-disabled'}}">{{ suffix }}</span>
   {% endif %}
   {% if label_display == 'after' %}
-    {% if show_description_toggle %}
+    {% if description_toggle %}
       <div class="help-icon">
         {{ label }}
         {{ attach_library('gin/gin_description_toggle') }}
@@ -70,7 +69,7 @@ js-form-type-[something] exists on form items. We have to keep them.
       {{ label }}
     {% endif %}
   {% endif %}
-  {% if show_description_toggle %}
+  {% if description_toggle %}
   </div>
   {% endif %}
   {% if errors %}
-- 
