From 3da578778bc5b0b58dce0486ef670c246a9dd165 Mon Sep 17 00:00:00 2001
From: Paul Weidner <paul.weidner@gmail.com>
Date: Wed, 15 Feb 2023 07:04:45 -0800
Subject: [PATCH 1/4] Standardize text format wrapper description preprocess
 logic

This existing logic is the same as the GinDescriptionToggle::preprocess
function except that it does not check if we are on a gin content form
route.

This fixes an issue where the description is always visually-hidden on
non gin content form routes and thus will never have a help toggle
button rendered.
---
 includes/form.theme | 7 +------
 1 file changed, 1 insertion(+), 6 deletions(-)

diff --git a/includes/form.theme b/includes/form.theme
index 4f99ebc4..1e42da5f 100644
--- a/includes/form.theme
+++ b/includes/form.theme
@@ -197,12 +197,7 @@ function gin_element_info_alter(&$info) {
  * Implements template_preprocess_HOOK() for text_format_wrapper.
  */
 function gin_preprocess_text_format_wrapper(&$variables) {
-  /** @var \Drupal\gin\GinSettings $settings */
-  $settings = \Drupal::classResolver(GinSettings::class);
-  if ($settings->get('show_description_toggle') && !empty($variables['description'])) {
-    $variables['description_display'] = 'invisible';
-    $variables['description_toggle'] = TRUE;
-  }
+  \Drupal::classResolver(GinDescriptionToggle::class)->preprocess($variables);
 }
 
 /**
-- 
