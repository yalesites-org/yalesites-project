From 2e55b2542e9b616130c7b09fb7488582a74f33e8 Mon Sep 17 00:00:00 2001
From: Marc Berger <marc@fourkitchens.com>
Date: Thu, 2 Jan 2025 12:18:05 -0800
Subject: [PATCH 1/4] feat(3497055): Only show help text to users who can edit
 lock settings

---
 layout_builder_lock.module | 23 +++++++++++++----------
 1 file changed, 13 insertions(+), 10 deletions(-)

diff --git a/layout_builder_lock.module b/layout_builder_lock.module
index 630c608..53116b1 100644
--- a/layout_builder_lock.module
+++ b/layout_builder_lock.module
@@ -32,6 +32,13 @@ function layout_builder_lock_form_layout_builder_configure_section_alter(&$form,
 
   $override = FALSE;
 
+  $lock_help_text = [
+    '#markup' => '<p>' . t('Locks can be configured when the section has been added.') . '</p>',
+    '#weight' => 100,
+  ];
+
+  $user_manage_locks_sections = \Drupal::currentUser()->hasPermission('manage lock settings on sections');
+
   // This is a hacky workaround, as the Layout Builder ConfigureSectionForm
   // has no public methods to expose if the user is adding or editing an
   // existing section.
@@ -41,11 +48,8 @@ function layout_builder_lock_form_layout_builder_configure_section_alter(&$form,
   // the ConfigureSectionForm.
   //
   // @see \Drupal\layout_builder\Form\ConfigureSectionForm::buildForm()
-  if (isset($form_state->getBuildInfo()['args'][2])) {
-    $form['layout_settings']['layout_builder_lock_info'] = [
-      '#markup' => '<p>' . t('Locks can be configured when the section has been added.') . '</p>',
-      '#weight' => 100,
-    ];
+  if (isset($form_state->getBuildInfo()['args'][2]) && $user_manage_locks_sections) {
+    $form['layout_settings']['layout_builder_lock_info'] = $lock_help_text;
     return;
   }
 
@@ -82,16 +86,15 @@ function layout_builder_lock_form_layout_builder_configure_section_alter(&$form,
     }
     catch (\Exception $ignored) {
       // No section yet, do not go further.
-      $form['layout_settings']['layout_builder_lock_info'] = [
-        '#markup' => '<p>' . t('Locks can be configured when the section has been added.') . '</p>',
-        '#weight' => 100,
-      ];
+      if ($override && $user_manage_locks_sections) {
+        $form['layout_settings']['layout_builder_lock_info'] = $lock_help_text;
+      }
       return;
     }
   }
 
   // Do not add the settings form when the user does not have permission.
-  if (!$override && !\Drupal::currentUser()->hasPermission('manage lock settings on sections')) {
+  if (!$override && !$user_manage_locks_sections) {
     if (isset($form['layout_settings']['layout_builder_lock_info'])) {
       $form['layout_settings']['layout_builder_lock_info']['#access'] = FALSE;
     }
-- 
GitLab


