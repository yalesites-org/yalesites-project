+  /**
+   * Get the relative URI for a search result entity.
+   *
+   * @param \Drupal\search_api\Item\ItemInterface $result
+   *   The search result item.
+   *
+   * @return string|null
+   *   Relative URI starting with /, or NULL if unavailable.
+   */
+  protected function getResultUri(\Drupal\search_api\Item\ItemInterface $result): ?string {
+    $entity_string = $result->getExtraData('drupal_entity_id');
+    if (!$entity_string) {
+      return NULL;
+    }
+    try {
+      $parts = explode(':', $entity_string);
+      if (count($parts) < 2) {
+        return NULL;
+      }
+      [$entity_type, $entity_id] = explode('/', $parts[1]);
+      $entity = $this->entityTypeManager->getStorage($entity_type)->load($entity_id);
+      if (!$entity) {
+        return NULL;
+      }
+      $url = $entity->toUrl();
+      $url->setAbsolute(FALSE);
+      return $url->toString();
+    }
+    catch (\Exception $e) {
+      return NULL;
+    }
+  }
+
 }
